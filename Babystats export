<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>BabyStats — Export</title>
<style>
  body { font-family: -apple-system, sans-serif; background: #F5EFE6; color: #1A1208; margin: 0; padding: 20px; }
  h1 { font-size: 22px; font-weight: 800; color: #D4621A; margin-bottom: 4px; }
  p { font-size: 14px; color: #7A6A55; margin-bottom: 20px; }
  .btn {
    display: block; width: 100%; max-width: 400px; margin: 0 auto 12px;
    padding: 14px; border-radius: 12px; border: none; cursor: pointer;
    font-size: 16px; font-weight: 700; font-family: inherit;
  }
  .btn-primary { background: #D4621A; color: white; }
  .btn-secondary { background: #EBE2D4; color: #4A3A28; }
  #status { text-align: center; font-size: 14px; color: #7A6A55; margin-top: 16px; }
  #preview {
    display: none; margin-top: 20px; background: white;
    border-radius: 12px; padding: 16px; font-size: 12px;
    font-family: monospace; white-space: pre-wrap; max-height: 300px;
    overflow-y: auto; border: 1px solid #D9CCBA; color: #4A3A28;
  }
  .center { text-align: center; }
</style>
</head>
<body>
<div class="center">
  <h1>⚽ BabyStats Export</h1>
  <p>Exporte toutes tes données en fichier Markdown téléchargeable.</p>
</div>

<button class="btn btn-primary" onclick="exportData()">📥 Exporter mes données (.md)</button>
<button class="btn btn-secondary" onclick="exportJSON()">🗄 Exporter en JSON brut</button>
<button class="btn btn-secondary" onclick="togglePreview()">👁 Aperçu</button>

<div id="status"></div>
<div id="preview"></div>

<script>
const DB_KEY = 'babystats_data';

function loadDB() {
  const raw = localStorage.getItem(DB_KEY);
  if (!raw) return null;
  return JSON.parse(raw);
}

function playerName(db, id) {
  return db.players.find(p => p.id === id)?.name || '?';
}
function teamName(db, id) {
  return db.teams.find(t => t.id === id)?.name || '?';
}
function phaseName(p) {
  return { poule:'Poule', quart:'Quart de finale', demi:'Demi-finale',
    finale:'Finale', petit_finale:'Petite finale', gala:'Match de gala',
    group:'Poule', quarter:'Quart de finale', semi:'Demi-finale',
    final:'Finale', third:'Petite finale' }[p] || p;
}

function getPlayerStats(db, pid) {
  let goals=0, pinches=0, saves=0, gamelles=0, ownGoals=0, wins=0, losses=0, draws=0;
  const allMatches = [
    ...(db.tournaments || []).flatMap(t => t.matches || []),
    ...(db.friendlyMatches || []),
    ...(db.matches || []),
  ];
  allMatches.forEach(m => {
    if (!m.finished && m.status !== 'done') return;
    // Ancienne architecture
    if (m.stats) {
      ['a','b'].forEach(side => {
        ['attacker','defender'].forEach(role => {
          const ps = m.stats[side]?.[role];
          if (!ps || ps.id !== pid) return;
          goals    += ps.goals    || 0;
          pinches  += ps.pinches  || 0;
          saves    += ps.saves    || 0;
          gamelles += ps.gamelles || 0;
          ownGoals += ps.ownGoals || 0;
          if (m.winner === side) wins++;
          else if (m.winner && m.winner !== side) losses++;
          else draws++;
        });
      });
    }
    // Nouvelle architecture
    if (m.players) {
      const pd = m.players[pid];
      if (pd) {
        goals    += pd.goals   || 0;
        saves    += pd.saves   || 0;
        pinches  += pd.shots   || 0;
        ownGoals += pd.csc     || 0;
        const t1 = (db.teams || []).find(t => t.id === m.team1Id);
        const t2 = (db.teams || []).find(t => t.id === m.team2Id);
        const isT1 = t1 && (t1.attackerId === pid || t1.defenderId === pid);
        const myScore = isT1 ? m.score1 : m.score2;
        const oppScore = isT1 ? m.score2 : m.score1;
        if (myScore > oppScore) wins++;
        else if (myScore < oppScore) losses++;
        else draws++;
      }
    }
  });
  const ratio = gamelles === 0 ? (goals > 0 ? '∞' : '—') : (goals / gamelles).toFixed(2);
  return { goals, pinches, saves, gamelles, ownGoals, wins, losses, draws, ratio };
}

function generateMarkdown(db) {
  const now = new Date().toLocaleDateString('fr-FR', { day:'2-digit', month:'long', year:'numeric' });
  let md = `# ⚽ BabyStats — Export du ${now}\n\n`;
  md += `> Données exportées depuis localStorage · Version DB : ${db.version || '?'}\n\n`;
  md += `---\n\n`;

  // ── JOUEURS ──
  md += `## 👤 Joueurs (${db.players.length})\n\n`;
  if (db.players.length) {
    md += `| # | Nom | Rôle | Buts | Pinches | Arrêts | Gamelles | CSC | V | D | N | Ratio B/G |\n`;
    md += `|---|-----|------|------|---------|--------|----------|-----|---|---|---|----------|\n`;
    db.players.forEach((p, i) => {
      const s = getPlayerStats(db, p.id);
      const role = p.role === 'attaquant' ? '⚔️ ATT' : p.role === 'defenseur' ? '🛡 DEF' : '⚽ Poly';
      md += `| ${i+1} | **${p.name}** | ${role} | ${s.goals} | ${s.pinches} | ${s.saves} | ${s.gamelles} | ${s.ownGoals} | ${s.wins} | ${s.losses} | ${s.draws} | ${s.ratio} |\n`;
    });
    md += '\n';

    // Top stats
    const sorted = db.players.map(p => ({ p, s: getPlayerStats(db, p.id) }));
    const topGoals   = [...sorted].sort((a,b) => b.s.goals - a.s.goals)[0];
    const topPinches = [...sorted].sort((a,b) => b.s.pinches - a.s.pinches)[0];
    const topSaves   = [...sorted].sort((a,b) => b.s.saves - a.s.saves)[0];
    const topGam     = [...sorted].sort((a,b) => b.s.gamelles - a.s.gamelles)[0];
    const topWins    = [...sorted].sort((a,b) => b.s.wins - a.s.wins)[0];
    md += `### 🏅 Records\n\n`;
    md += `- 🥇 **Ballon d'Or** : ${topGoals?.p.name} (${topGoals?.s.goals} buts)\n`;
    md += `- 🤏 **Master of Pinch** : ${topPinches?.p.name} (${topPinches?.s.pinches} pinches)\n`;
    md += `- 🛡 **Master of Defence** : ${topSaves?.p.name} (${topSaves?.s.saves} arrêts)\n`;
    md += `- 😬 **Machine à Gamelle** : ${topGam?.p.name} (${topGam?.s.gamelles} gamelles)\n`;
    md += `- 🏆 **Plus de victoires** : ${topWins?.p.name} (${topWins?.s.wins} victoires)\n\n`;
  } else {
    md += `_Aucun joueur._\n\n`;
  }

  md += `---\n\n`;

  // ── ÉQUIPES ──
  md += `## 👥 Équipes (${db.teams.length})\n\n`;
  if (db.teams.length) {
    db.teams.forEach(t => {
      const atk = playerName(db, t.attackerId);
      const def = playerName(db, t.defenderId);
      let wins = 0;
      const allM = [...(db.tournaments||[]).flatMap(to=>to.matches||[]), ...(db.friendlyMatches||[]), ...(db.matches||[])];
      allM.forEach(m => {
        if (!m.finished && m.status !== 'done') return;
        if ((m.winner==='a'&&m.teamA===t.id)||(m.winner==='b'&&m.teamB===t.id)) wins++;
        if (m.winner===t.id) wins++;
      });
      md += `- **${t.name}** · ⚔️ ${atk} + 🛡 ${def} · 🏆 ${wins} victoires\n`;
    });
    md += '\n';
  } else {
    md += `_Aucune équipe._\n\n`;
  }

  md += `---\n\n`;

  // ── TOURNOIS ──
  md += `## 🏆 Tournois (${db.tournaments.length})\n\n`;
  (db.tournaments || []).forEach((t, ti) => {
    const date = t.date ? new Date(t.date).toLocaleDateString('fr-FR') : '?';
    const done = (t.matches||[]).filter(m=>m.finished).length;
    const total = (t.matches||[]).length;
    const status = t.status === 'finished' ? '✅ Terminé' : '🔄 En cours';
    md += `### ${ti+1}. ${t.name}\n\n`;
    md += `- **Date** : ${date}\n`;
    md += `- **Statut** : ${status}\n`;
    md += `- **Équipes** : ${(t.teams||[]).map(id=>teamName(db,id)).join(', ')}\n`;
    md += `- **Matchs** : ${done}/${total} joués\n`;
    md += `- **Durée par match** : ${t.matchDuration||5} min\n`;
    if (t.refereeId) md += `- **Arbitre** : ${playerName(db, t.refereeId)}\n`;
    md += '\n';

    // Matchs
    if (t.matches?.length) {
      md += `#### Résultats\n\n`;
      md += `| Phase | Équipe A | Score | Équipe B |\n`;
      md += `|-------|----------|-------|----------|\n`;
      t.matches.filter(m=>m.finished).forEach(m => {
        const na = teamName(db, m.teamA), nb = teamName(db, m.teamB);
        const wA = m.winner==='a', wB = m.winner==='b';
        md += `| ${phaseName(m.phase)} | ${wA?'**':''}${na}${wA?'** ✓':''} | ${m.scoreA}–${m.scoreB} | ${wB?'**':''}${nb}${wB?'** ✓':''} |\n`;
      });
      md += '\n';
    }
  });

  if (!db.tournaments.length) md += `_Aucun tournoi._\n\n`;

  md += `---\n\n`;

  // ── MATCHS AMICAUX ──
  const friendly = db.friendlyMatches || [];
  if (friendly.length) {
    md += `## ⚽ Matchs amicaux (${friendly.length})\n\n`;
    md += `| Équipe A | Score | Équipe B |\n`;
    md += `|----------|-------|----------|\n`;
    friendly.filter(m=>m.finished).forEach(m => {
      const na = teamName(db, m.teamA), nb = teamName(db, m.teamB);
      const wA = m.winner==='a', wB = m.winner==='b';
      md += `| ${wA?'**':''}${na}${wA?'** ✓':''} | ${m.scoreA}–${m.scoreB} | ${wB?'**':''}${nb}${wB?'** ✓':''} |\n`;
    });
    md += '\n---\n\n';
  }

  // ── RAW JSON ──
  md += `## 🗄 Données brutes (JSON)\n\n`;
  md += `\`\`\`json\n${JSON.stringify(db, null, 2)}\n\`\`\`\n`;

  return md;
}

function exportData() {
  const db = loadDB();
  if (!db) { setStatus('❌ Aucune donnée BabyStats trouvée dans ce navigateur.'); return; }
  const md = generateMarkdown(db);
  download('babystats_export.md', md, 'text/markdown');
  setStatus('✅ Export téléchargé !');
}

function exportJSON() {
  const db = loadDB();
  if (!db) { setStatus('❌ Aucune donnée BabyStats trouvée dans ce navigateur.'); return; }
  download('babystats_data.json', JSON.stringify(db, null, 2), 'application/json');
  setStatus('✅ JSON téléchargé !');
}

function togglePreview() {
  const db = loadDB();
  const el = document.getElementById('preview');
  if (el.style.display === 'block') { el.style.display = 'none'; return; }
  if (!db) { setStatus('❌ Aucune donnée BabyStats trouvée dans ce navigateur.'); return; }
  el.textContent = generateMarkdown(db).slice(0, 3000) + '\n\n... (aperçu tronqué)';
  el.style.display = 'block';
}

function download(filename, content, type) {
  const blob = new Blob([content], { type });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = filename;
  document.body.appendChild(a); a.click();
  document.body.removeChild(a); URL.revokeObjectURL(url);
}

function setStatus(msg) {
  document.getElementById('status').textContent = msg;
}

// Auto-check
window.onload = () => {
  const db = loadDB();
  if (!db) {
    setStatus('⚠️ Ouvre cet outil depuis le même navigateur/domaine que BabyStats.');
  } else {
    setStatus(`✅ Données trouvées : ${db.players?.length||0} joueurs · ${db.teams?.length||0} équipes · ${db.tournaments?.length||0} tournois`);
  }
};
</script>
</body>
</html>
